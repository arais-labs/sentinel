# Sentinel local-prod settings.
# Copy to .env for the default CLI/prod stack and replace every placeholder.

COMPOSE_PROJECT_NAME=sentinel
STACK_PORT=4747
SENTINEL_RUNTIME_BACKEND=docker

# Infrastructure secrets. Prod refuses placeholder/default values.
SENTINEL_POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
SENTINEL_JWT_SECRET_KEY=replace-with-a-long-random-jwt-secret

# Optional external Postgres target for the backend container. Leave unset for
# the default Docker Compose postgres service. For a host-running Postgres,
# Docker containers usually need host.docker.internal rather than 127.0.0.1.
# SENTINEL_DATABASE_HOST=host.docker.internal
# SENTINEL_DATABASE_PORT=15452
# SENTINEL_DATABASE_USER=sentinel
# SENTINEL_DATABASE_PASSWORD=sentinel
# SENTINEL_DATABASE_MAINTENANCE_NAME=postgres
# SENTINEL_DATABASE_MANAGER_NAME=sentinel_manager

# App admin credentials. .env is the source of truth; backend stores only a
# password hash in the manager DB and syncs it from these values on startup.
SENTINEL_AUTH_USERNAME=replace-with-admin-username
SENTINEL_AUTH_PASSWORD=replace-with-a-local-admin-password

# Host runtime workspace root. Must be absolute because Docker/QEMU runtime
# providers mount it from outside the backend container.
# Dev setup proposes <repo>/.sentinel/runtime/workspaces.
SENTINEL_RUNTIME_WORKSPACES_DIR=/absolute/path/to/sentinel/.sentinel/runtime/workspaces

# Optional when SENTINEL_RUNTIME_BACKEND=qemu for CLI/Docker stacks.
# The CLI can write these values with:
#   ./sentinel-cli.sh runtime backend qemu
# This directory is mounted into the backend container at the same absolute
# path so both the container and host-side QEMU bridge can read the artifacts.
# SENTINEL_QEMU_ARTIFACTS_DIR=/absolute/path/to/sentinel/infra/runtime/qemu/output
# SENTINEL_QEMU_BRIDGE_URL=http://host.docker.internal:47481
# SENTINEL_QEMU_BRIDGE_TOKEN=replace-with-a-local-qemu-bridge-token
# SENTINEL_QEMU_RUN_ROOT=/absolute/path/to/sentinel/.sentinel/runtime/qemu
