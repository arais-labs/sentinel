#!/usr/bin/env bash
set -euo pipefail

message_file="${1:-}"
if [[ -z "$message_file" || ! -f "$message_file" ]]; then
  echo "commit-msg hook error: missing commit message file."
  exit 1
fi

subject="$(grep -m1 -Ev '^\s*$' "$message_file" || true)"
if [[ -z "$subject" ]]; then
  echo "Commit message cannot be empty."
  exit 1
fi

# Skip merge/revert auto messages.
if [[ "$subject" =~ ^Merge[[:space:]] ]] || [[ "$subject" =~ ^Revert[[:space:]] ]]; then
  exit 0
fi

subject_len="${#subject}"
if [[ "$subject_len" -gt 72 ]]; then
  echo "Commit message subject is too long ($subject_len > 72)."
  exit 1
fi

if echo "$subject" | grep -Eiq '^(wip|fixup!|squash!)'; then
  echo "Commit message subject uses a temporary prefix (wip/fixup!/squash!)."
  exit 1
fi

# Enforce Conventional Commits: type(optional scope)(optional !): description
conventional_regex='^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9._/-]+\))?(!)?: .+'
if ! echo "$subject" | grep -Eq "$conventional_regex"; then
  echo "Commit message must follow Conventional Commits."
  echo "  Format: <type>(<optional scope>): <description>"
  echo "  Types:  build, chore, ci, docs, feat, fix, perf, refactor, revert, style, test"
  echo "  Example: feat(runtime): add ssh target health probe"
  exit 1
fi
