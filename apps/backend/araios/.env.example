# araiOS backend production example environment file.
# Copy to `.env` and replace placeholder values before production deploy.

DATABASE_URL=postgresql://araios:araios@db:5432/araios
ENV=production

JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
