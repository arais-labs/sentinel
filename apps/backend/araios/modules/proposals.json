{
  "name": "proposals",
  "label": "Proposals",
  "description": "Track proposals, deal values, and pipeline status",
  "icon": "FileText",
  "type": "data",
  "order": 30,
  "fields": [
    {"key": "proposal_title", "label": "Title",     "type": "text",   "required": true},
    {"key": "lead_name",      "label": "Lead",      "type": "text"},
    {"key": "company",        "label": "Company",   "type": "text"},
    {"key": "value",          "label": "Value ($)", "type": "number"},
    {"key": "status",         "label": "Status",    "type": "select",
     "options": ["draft", "sent", "viewed", "accepted", "declined", "expired"]},
    {"key": "sent_at",        "label": "Sent At",   "type": "date"},
    {"key": "notes",          "label": "Notes",     "type": "textarea"}
  ],
  "list_config": {
    "titleField":    "proposal_title",
    "subtitleField": "company",
    "badgeField":    "status",
    "metaField":     "value",
    "filterField":   "status"
  },
  "actions": [
    {"id": "create", "label": "New Proposal", "placement": "sub-header", "type": "create"},
    {"id": "delete", "label": "Delete",       "placement": "detail",     "type": "delete", "confirm": true}
  ],
  "secrets": []
}
