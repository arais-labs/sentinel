{
  "name": "clients",
  "label": "Clients",
  "description": "Manage active client engagements and health status",
  "icon": "Briefcase",
  "type": "data",
  "order": 20,
  "fields": [
    {"key": "name",            "label": "Name",           "type": "text",   "required": true},
    {"key": "company",         "label": "Company",        "type": "text"},
    {"key": "email",           "label": "Email",          "type": "email"},
    {"key": "linked_in",       "label": "LinkedIn",       "type": "url"},
    {"key": "engagement_type", "label": "Engagement",     "type": "select",
     "options": ["xcelerator", "retainer", "advisory"]},
    {"key": "phase",           "label": "Phase",          "type": "select",
     "options": ["audit", "build", "deploy", "handover", "complete"]},
    {"key": "health_status",   "label": "Health",         "type": "select",
     "options": ["green", "yellow", "red"]},
    {"key": "contract_value",  "label": "Contract Value", "type": "text"},
    {"key": "start_date",      "label": "Start Date",     "type": "date"},
    {"key": "notes",           "label": "Notes",          "type": "textarea"}
  ],
  "list_config": {
    "titleField":    "name",
    "subtitleField": "company",
    "badgeField":    "phase",
    "metaField":     "health_status",
    "filterField":   "phase"
  },
  "actions": [
    {"id": "create", "label": "New Client", "placement": "sub-header", "type": "create"},
    {"id": "delete", "label": "Delete",     "placement": "detail",     "type": "delete", "confirm": true}
  ],
  "secrets": []
}
