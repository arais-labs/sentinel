# Sentinel backend production example environment file.
# Copy to `.env` and replace placeholder values before production deploy.

# App runtime
APP_NAME=Sentinel API
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
BACKEND_PORT=8000

# Database
POSTGRES_DB=sentinel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/sentinel

# Auth / JWT
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# araiOS integration
ARAIOS_URL=
SSRF_ALLOW_HOSTS=

# Development fallback token (disable in production)
DEV_TOKEN=disabled-in-prod

# Webhook signature secret
WEBHOOK_SECRET=replace-with-webhook-secret
